# Шаблон для сервера: скопируй в /opt/watermelon-messenger/.env
# GitHub Secret PROD_ENV_FILE = полное содержимое этого файла (заполненного)

NODE_ENV=production
WM_DOMAIN=watermelon-messenger.ru
# nginx.http.conf до certbot-init, потом nginx.prod.conf (certbot-init.sh пропишет)
WM_NGINX_CONF=nginx.http.conf

# plwatermelon/watermelon-messenger-{api,web}:X.Y.Z — WM_VERSION пропишет deploy-server.sh
WM_VERSION= 
# certbot: автоматически в deploy-server.sh (CERTBOT_EMAIL обязателен в .env / PROD_ENV_FILE)
CERTBOT_EMAIL=you@example.com

POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

JWT_SECRET=
MESSAGE_AT_REST_KEY=

YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=https://watermelon-messenger.ru/api/auth/yandex/callback
YANDEX_NATIVE_REDIRECT_URI=watermelon://oauth/yandex
WEB_URL=https://watermelon-messenger.ru

ADMIN_YANDEX_LOGINS=platinumwatermelon
ADMIN_YANDEX_IDS=

YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
PLATINUM_PRICE_RUB=299
API_PUBLIC_URL=https://watermelon-messenger.ru/api

# MinIO — обязательно в PROD_ENV_FILE / .env
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
S3_BUCKET=watermelon-media

# Web Push в браузере (Chrome/Firefox/Safari) — НЕ email.
# Ключи — криптопара для протокола Web Push API; письма никому не шлются.
# Сгенерировать: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Яндекс Карты — только превью геометки в чате (опционально, без ключа работает виджет)
# Выбор точки на карте — OpenStreetMap, ключ не нужен
# VITE_YANDEX_MAPS_API_KEY=
# Соцсети на странице ожидания beta (опционально, есть дефолты)
# VITE_VK_URL=https://vk.com/watermelon_messenger
# VITE_TELEGRAM_URL=https://t.me/watermelon_messenger
# Опционально (по умолчанию берётся WEB_URL):
# VAPID_SUBJECT=https://watermelon-messenger.ru

# Grafana (только внутри docker-сети, UI — через админку в настройках)
# GRAFANA_ADMIN_PASSWORD=change-me
