# Шаблон для сервера: скопируй в /opt/watermelon-messenger/.env
# GitHub Secret PROD_ENV_FILE = полное содержимое этого файла (заполненного)

NODE_ENV=production
WM_DOMAIN=watermelon-messenger.ru
# nginx.http.conf до certbot-init, потом nginx.prod.conf (certbot-init.sh пропишет)
WM_NGINX_CONF=nginx.http.conf

# plwatermelon/watermelon-messenger-{api,web}:X.Y.Z — WM_VERSION пропишет deploy-server.sh
WM_VERSION=
# certbot: автоматически в deploy-server.sh (CERTBOT_EMAIL обязателен в .env / PROD_ENV_FILE)
CERTBOT_EMAIL=you@example.com

POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

JWT_SECRET=
MESSAGE_AT_REST_KEY=

YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=https://watermelon-messenger.ru/api/auth/yandex/callback
YANDEX_NATIVE_REDIRECT_URI=watermelon://oauth/yandex
WEB_URL=https://watermelon-messenger.ru

ADMIN_YANDEX_LOGINS=platinumwatermelon
ADMIN_YANDEX_IDS=

YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
PLATINUM_PRICE_RUB=299
API_PUBLIC_URL=https://watermelon-messenger.ru/api

# MinIO — обязательно в PROD_ENV_FILE / .env
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
S3_BUCKET=watermelon-media

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@watermelon-messenger.ru
