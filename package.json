{
  "name": "watermelon-messenger",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "export:favicon": "node scripts/export-favicon-ico.mjs",
    "indexnow:ping": "node scripts/indexnow-ping.mjs",
    "dev:api": "bun run --cwd apps/api dev",
    "dev:web": "bun run --cwd apps/web dev",
    "build": "bun run --cwd apps/api build && bun run --cwd apps/web build",
    "test": "bun test apps/api/src/tests/unit.test.ts apps/api/src/tests/messageRead.test.ts apps/api/src/tests/timeUuid.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:generate": "bun run --cwd apps/api db:generate",
    "db:migrate": "bun run --cwd apps/api db:migrate",
    "db:studio": "bun run --cwd apps/api db:studio"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "concurrently": "^9.1.0",
    "pngjs": "^7.0.0"
  }
}
